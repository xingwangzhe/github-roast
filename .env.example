# ── GitHub data (required) ────────────────────────────────────────────────
# A read-only PAT (classic: public_repo / no scopes needed for public data, or a
# fine-grained token with public read). Lifts rate limits from 60/h to 5000/h and
# enables the GraphQL contribution queries.
GITHUB_TOKEN=ghp_xxx

# ── Default LLM (operator-funded; StepFun 阶跃星辰 by default) ─────────────
# OpenAI-compatible. The operator key so visitors don't need their own; when this
# balance/quota is exhausted, the app prompts users to bring their own key.
# Default base = https://api.stepfun.com/v1, default model = step-3.7-flash.
LLM_API_KEY=
LLM_MODEL=step-3.7-flash
# LLM_BASE_URL=https://api.stepfun.com/v1     # override for OpenAI/OpenRouter/Groq/etc
#
# Other OpenAI-compatible providers — just point the three vars at them, e.g.:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-4o-mini
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama-3.3-70b-versatile

# ── Cache + rate limiting (optional but recommended) ──────────────────────
# Upstash Redis (free tier). Caches scans 24h by username and rate-limits per IP.
# If absent, both silently no-op (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Human verification (optional but recommended in prod) ─────────────────
# Cloudflare Turnstile (free). If absent, the human-check is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Leaderboard + percentile (optional) ───────────────────────────────────
# Turso / libSQL. Stores one row per scanned account for the 名人堂 board and the
# "你超越了 X%" percentile. If absent, the leaderboard/percentile silently disable.
#   Cloud:  turso db create github-roast && turso db tokens create github-roast
#   Local:  TURSO_DATABASE_URL=file:./local.db   (no auth token needed)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── arXiv 论文锐评: citation signals (optional but recommended) ────────────
# Semantic Scholar key. The keyless pool 429s under any load, which zeroes out
# every paper's citation bonus and caps scores at the 80-pt content ceiling
# (nothing reaches the 90+ 神作 tier). Free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Secret for the one-off citation rescore backfill (POST /api/paper/admin/rescore
# with header `x-admin-secret`). No default → the endpoint is inert until set.
ADMIN_SECRET=

# Public site URL (used for OpenRouter attribution + share links, badge/card embeds)
NEXT_PUBLIC_SITE_URL=https://githubroast.dev
# Server-side alias (optional, overridden by NEXT_PUBLIC_SITE_URL when set)
PUBLIC_SITE_URL=https://githubroast.dev

# ── 用户登录 / GitHub OAuth (optional) ────────────────────────────────────
# Lets visitors "Login with GitHub" (identity only for now). If these are
# absent, the login entry is hidden and everything else works unchanged.
# Create a GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL              = https://githubroast.dev
#   Authorization callback URL = https://githubroast.dev/api/auth/callback/github
#   For local dev, add another or use http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Session signing secret. Generate: openssl rand -base64 33   (or: npx auth secret)
AUTH_SECRET=
# Usually auto-trusted on Vercel; set to true only if login callbacks misbehave.
# AUTH_TRUST_HOST=true
